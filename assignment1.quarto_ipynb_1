   "source": [
    "def normalize(data):\n",
    "    \"\"\"Normalize a sequence of values so they add up to 1.\n",
    "\n",
    "    Parameters:\n",
    "        data: A row or sequence of numeric values.\n",
    "\n",
    "    Returns:\n",
    "        A normalized version of the input data.\n",
    "    \"\"\"\n",
    "    total = data.sum()\n",
    "    if total == 0:\n",
    "        return data\n",
    "    return data / total"
   ]
  },
